<clackhouse-theme-toggle
  class="theme-toggle inline-flex h-10 items-center rounded-full border border-line bg-panel-900/80 p-1"
  aria-label="Select theme"
>
  <button
    type="button"
    data-theme-option="auto"
    aria-label="Use system theme"
    title="System theme"
  >
    Auto
  </button>
  <button
    type="button"
    data-theme-option="dark"
    aria-label="Use dark theme"
    title="Dark theme"
  >
    Dark
  </button>
  <button
    type="button"
    data-theme-option="light"
    aria-label="Use light theme"
    title="Light theme"
  >
    Light
  </button>
</clackhouse-theme-toggle>

<script>
  type Theme = "auto" | "dark" | "light";

  const storageKey = "starlight-theme";
  const darkThemeColor = "#0b0d10";
  const lightThemeColor = "#f4f6f1";
  const starlightWindow = window as Window & {
    StarlightThemeProvider?: { updatePickers(theme?: Theme): void };
  };

  const parseTheme = (theme: unknown): Theme =>
    theme === "auto" || theme === "dark" || theme === "light" ? theme : "auto";

  const getStoredTheme = (): Theme =>
    parseTheme(
      typeof localStorage !== "undefined" && localStorage.getItem(storageKey),
    );

  const getPreferredTheme = (): Exclude<Theme, "auto"> =>
    matchMedia("(prefers-color-scheme: light)").matches ? "light" : "dark";

  const resolveTheme = (theme: Theme): Exclude<Theme, "auto"> =>
    theme === "auto" ? getPreferredTheme() : theme;

  function syncButtons(theme: Theme) {
    document.querySelectorAll("clackhouse-theme-toggle").forEach((toggle) => {
      toggle
        .querySelectorAll<HTMLButtonElement>("button[data-theme-option]")
        .forEach((button) => {
          button.setAttribute(
            "aria-pressed",
            String(button.dataset.themeOption === theme),
          );
        });
    });
  }

  function applyTheme(theme: Theme) {
    const resolvedTheme = resolveTheme(theme);
    document.documentElement.dataset.theme = resolvedTheme;

    const themeColor = document.querySelector('meta[name="theme-color"]');
    if (themeColor instanceof HTMLMetaElement) {
      themeColor.content =
        resolvedTheme === "light" ? lightThemeColor : darkThemeColor;
    }

    if (typeof localStorage !== "undefined") {
      localStorage.setItem(storageKey, theme === "auto" ? "" : theme);
    }

    starlightWindow.StarlightThemeProvider?.updatePickers(theme);
    syncButtons(theme);
  }

  matchMedia("(prefers-color-scheme: light)").addEventListener("change", () => {
    if (getStoredTheme() === "auto") applyTheme("auto");
  });

  class ClackHouseThemeToggle extends HTMLElement {
    connectedCallback() {
      syncButtons(getStoredTheme());
      this.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const button = target.closest<HTMLButtonElement>(
          "button[data-theme-option]",
        );
        if (!button) return;
        applyTheme(parseTheme(button.dataset.themeOption));
      });
    }
  }

  if (!customElements.get("clackhouse-theme-toggle")) {
    customElements.define("clackhouse-theme-toggle", ClackHouseThemeToggle);
  }
</script>
