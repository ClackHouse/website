---
import MarketingLayout from "../layouts/MarketingLayout.astro";
import { privacyMachineMarkdown, privacyPage } from "../data/site";
---

<MarketingLayout
  title={`ClackHouse - ${privacyPage.title}`}
  description={privacyPage.description}
  machineContent={privacyMachineMarkdown}
>
  <!-- Hero -->
  <section class="mx-auto max-w-6xl px-6 pb-12 pt-16 lg:px-8 lg:pb-16 lg:pt-22">
    <div class="max-w-2xl ai-readable">
      <p
        class="font-mono text-xs font-bold uppercase tracking-[0.28em] text-signal-300"
      >
        Privacy model
      </p>
      <h1
        class="mt-4 font-mono text-5xl font-medium leading-[0.93] tracking-[-0.05em] text-fog-50 sm:text-6xl"
      >
        {privacyPage.title}
      </h1>
      <p class="mt-6 text-lg leading-8 text-fog-200">
        {privacyPage.description}
      </p>
    </div>
  </section>

  <!-- Privacy sections as cards -->
  {
    (() => {
      const sectionIcons = [
        `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3L4 7v6c0 5.55 4.27 10.74 10 12 5.73-1.26 10-6.45 10-12V7L14 3z" stroke="var(--theme-signal-400)" stroke-width="1.5" fill="var(--theme-signal-400)" fill-opacity="0.06"/><line x1="10" y1="14" x2="18" y2="14" stroke="var(--theme-signal-400)" stroke-width="1.2" stroke-linecap="round"/></svg>`,
        `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><rect x="6" y="8" width="16" height="12" rx="2" stroke="var(--theme-signal-400)" stroke-width="1.5" fill="var(--theme-signal-400)" fill-opacity="0.06"/><path d="M10 14h8M10 17h5" stroke="var(--theme-signal-400)" stroke-width="1.2" stroke-linecap="round" opacity="0.5"/><circle cx="14" cy="5" r="2" stroke="var(--theme-signal-400)" stroke-width="1.2" opacity="0.6"/><path d="M14 7v1" stroke="var(--theme-signal-400)" stroke-width="1.2" stroke-linecap="round" opacity="0.4"/></svg>`,
        `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="10" stroke="var(--theme-signal-400)" stroke-width="1.5" fill="var(--theme-signal-400)" fill-opacity="0.06"/><path d="M10 14l3 3 5-6" stroke="var(--theme-signal-400)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
      ];
      const sectionDescriptions = privacyPage.sections.map(
        (s) => s.description,
      );
      const isAlt = (i: number) => i % 2 === 0;
      return privacyPage.sections.map((section, i) => (
        <section
          class:list={[
            "reveal",
            isAlt(i) ? "border-y border-line-soft bg-wash" : "",
          ]}
        >
          <div class="mx-auto max-w-6xl px-6 py-20 lg:px-8">
            <div
              class:list={[
                "ai-grid-collapse ai-tight grid gap-12 lg:items-center",
                isAlt(i)
                  ? "lg:grid-cols-[1.6fr_1fr]"
                  : "lg:grid-cols-[1fr_1.6fr]",
              ]}
            >
              {/* Cards column */}
              <div
                class:list={[
                  "grid gap-4 sm:grid-cols-1",
                  isAlt(i) ? "order-2 lg:order-1" : "order-2",
                ]}
              >
                {section.points.map((point) => (
                  <article class="ai-flatten ai-surface flex items-center gap-4 rounded-2xl border border-line bg-panel-900/84 p-5">
                    <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-signal-400" />
                    <p class="text-lg leading-8 text-fog-100">{point}</p>
                  </article>
                ))}
              </div>

              {/* Text column */}
              <div
                class:list={[
                  "ai-readable",
                  isAlt(i) ? "order-1 lg:order-2" : "order-1",
                ]}
              >
                <div
                  class="flex h-11 w-11 items-center justify-center rounded-lg border border-signal-500/15 bg-signal-500/5"
                  set:html={sectionIcons[i]}
                />
                <h2 class="mt-4 font-mono text-3xl text-fog-50 sm:text-4xl lg:text-5xl">
                  {section.title}
                </h2>
                <p class="mt-4 text-lg leading-8 text-fog-200">
                  {sectionDescriptions[i]}
                </p>
              </div>
            </div>
          </div>
        </section>
      ));
    })()
  }
</MarketingLayout>
